# Veyron Backend Environment Variables
# Copy this file to .env and fill in with your actual keys

# ================== REQUIRED API KEYS ==================
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Get from: https://www.virustotal.com (in API Key section)
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# Get from: https://console.cloud.google.com/ (Safe Browsing API)
SAFE_BROWSING_API_KEY=your_safe_browsing_api_key_here

# Get from: https://haveibeenpwned.com/ (optional, for email breach checking)
HIBP_API_KEY=your_hibp_api_key_here

# ================== OPTIONAL FIREBASE ==================
# Leave empty if not using Firebase
FIREBASE_CREDENTIALS_PATH=
FIREBASE_PROJECT_ID=

# ================== CORS & SECURITY ==================
# Comma-separated list of allowed origins
# Development: http://localhost,http://localhost:3000,http://localhost:5173
# Production: https://veyron-frontend.vercel.app,https://your-custom-domain.com
ALLOWED_ORIGINS=http://localhost,http://localhost:3000,http://localhost:5173,https://veyron-frontend.vercel.app

# ================== APP CONFIGURATION ==================
# Environment: development, staging, production
APP_ENV=development

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=DEBUG

# Rate limit per minute
RATE_LIMIT_PER_MINUTE=100

# Server port
PORT=8000

